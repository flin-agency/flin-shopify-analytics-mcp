SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_API_VERSION=2026-04

# Option 1 (recommended for new Dev Dashboard apps): OAuth client credentials
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=your_client_secret

# Option 2 (legacy custom apps): static admin access token
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Optional custom CA bundle for TLS / proxy environments
# SHOPIFY_CA_BUNDLE=/path/to/ca-bundle.pem

# Optional tuning for automatic token refresh
# SHOPIFY_OAUTH_REFRESH_SKEW_SECONDS=60
# SHOPIFY_OAUTH_TOKEN_TTL_FALLBACK_SECONDS=86399
